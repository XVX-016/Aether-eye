APP_NAME=Aether Eye API
APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=info

DATABASE_URL=postgresql+asyncpg://aether:aether@db:5432/aether_eye
SQL_ECHO=false
BACKEND_API_BASE_URL=http://backend:8000/api

# STAC watcher
ENABLE_STAC_WATCHER=false
STAC_POLL_MINUTES=360
STAC_CONFIG_PATH=backend/configs/ingestion/stac.yaml

# Activity aggregation
ENABLE_ACTIVITY_AGGREGATOR=true
ACTIVITY_WINDOW_HOURS=24
ACTIVITY_SURGE_FACTOR=2.0
ACTIVITY_MIN_COUNT=3

# Model paths inside the container
AIRCRAFT_DETECTOR_ONNX_PATH=/models/yolov8_aircraft.onnx
CHANGE_DETECTOR_ONNX_PATH=/models/siamese_change.onnx
VIT_AIRCRAFT_WEIGHTS_PATH=/models/vit_fgvc_aircraft_best.pt

# Inference thresholds
AIRCRAFT_CONF_THRESHOLD=0.25
AIRCRAFT_IOU_THRESHOLD=0.45

# ViT aircraft classification
VIT_AIRCRAFT_NUM_CLASSES=100
VIT_AIRCRAFT_MODEL_NAME=vit_base_patch16_224
VIT_AIRCRAFT_IMAGE_SIZE=224
AIRCRAFT_CLASSIFIER_CONFIG_PATH=backend/configs/inference/aircraft_classifier.yaml
CHANGE_DETECTOR_CONFIG_PATH=backend/configs/inference/change_detector.yaml
